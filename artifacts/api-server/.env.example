# ── Required ────────────────────────────────────────────────────────────────
# Minimum 32-char random string (e.g. openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_long_random_string

# Bearer token for fund-risk / mutating routes (POST /bot/*, DELETE /orders/*, etc.)
ADMIN_TOKEN=change_me_to_another_long_random_string

# ── Optional: builder tracking ───────────────────────────────────────────────
# Your Polymarket builder code (shows builder leaderboard, fee revenue)
# POLY_BUILDER_CODE=your_builder_code_here

# ── Optional: wallet / portfolio ─────────────────────────────────────────────
# Your wallet address (enables portfolio / positions pages)
# POLY_ADDRESS=0xYourWalletAddress

# ── Optional: CLOB authenticated endpoints ───────────────────────────────────
# WARNING: POLY_PRIVATE_KEY controls real funds. Never commit this file.
# Required for order placement, live rewards, and position management.
#
# POLY_PRIVATE_KEY=0xYourPrivateKeyHere
# POLY_API_KEY=your_clob_api_key
# POLY_API_SECRET=your_clob_api_secret
# POLY_API_PASSPHRASE=your_clob_api_passphrase
#
# Proxy wallet address from polymarket.com/settings → Builder tab ("For API use only")
# CLOB_PROXY_URL=0xYourProxyWalletAddress
#
# Relayer API key
# RELAYER_API_KEY=your_relayer_api_key
