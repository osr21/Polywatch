modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
RELAYER_API_KEY_ADDRESS = "0xB14436dECe0E552b06ad88dC32e5644eBCbA8F4D"
NOTIFY_EMAIL = "tobimax241@gmail.com"
